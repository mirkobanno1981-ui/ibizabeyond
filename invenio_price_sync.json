            ],
            "id": "get-wp-properties",
            "name": "WP - Get All Properties"
        },
        {
            "parameters": {
                "jsCode": "// === BUILD MATCH MAP ===\n// Unisce Invenio villas+prices con WP properties tramite v_uuid\n// Usa endpoint ibiza-beyond/v1/properties/all\nconst villasRaw = $('Invenio - Get Villas').first().json;\nconst pricesRaw = $('Invenio - Get Prices').first().json;\nconst wpRaw = $('WP - Get All Properties').first().json;\nconst villas = villasRaw.villas || [];\nconst priceData = pricesRaw.price_data || {};\nconst today = new Date().toISOString().slice(0, 10);\n\n// Parse WP properties - potrebbe essere un array diretto o un oggetto con proprietà\nlet wpProperties = [];\nif (Array.isArray(wpRaw)) {\n  wpProperties = wpRaw;\n} else if (wpRaw && typeof wpRaw === 'object') {\n  // potrebbe essere { properties: [...] } o { data: [...] } o simile\n  wpProperties = wpRaw.properties || wpRaw.data || Object.values(wpRaw).find(v => Array.isArray(v)) || [];\n}\n\n// Build WP lookup: v_uuid -> {id, title}\nconst wpLookup = {};\nconst wpDebug = [];\nfor (const p of wpProperties) {\n  let uuid = null;\n  // Cerca v_uuid in diversi posti possibili\n  if (p.v_uuid) uuid = String(p.v_uuid);\n  else if (p.meta && p.meta.v_uuid) uuid = String(Array.isArray(p.meta.v_uuid) ? p.meta.v_uuid[0] : p.meta.v_uuid);\n  else if (p.custom_fields && p.custom_fields.v_uuid) uuid = String(Array.isArray(p.custom_fields.v_uuid) ? p.custom_fields.v_uuid[0] : p.custom_fields.v_uuid);\n  else if (p.acf && p.acf.v_uuid) uuid = String(p.acf.v_uuid);\n  \n  if (uuid) wpLookup[uuid] = { id: p.id || p.ID, title: p.title || p.post_title || '' };\n  if (wpDebug.length < 3) wpDebug.push({ id: p.id || p.ID, keys: Object.keys(p).slice(0, 15), title: p.title || p.post_title || 'N/A' });\n}\n\n// Match Invenio villas con WP\nconst results = [];\nfor (const villa of villas) {\n  if (villa.destination !== 'Ibiza') continue;\n  const uuid = villa.v_uuid;\n  const periods = priceData[uuid];\n  if (!Array.isArray(periods) || periods.length === 0) continue;\n  const validPrices = periods\n    .filter(p => p && p.start_date && p.end_date && p.amount && p.end_date >= today)\n    .map(p => ({ date_range: { from: p.start_date, to: p.end_date }, price: String(p.amount) }));\n  if (validPrices.length === 0) continue;\n  const wpMatch = wpLookup[uuid];\n  results.push({ json: {\n    skip: !wpMatch,\n    wp_id: wpMatch ? wpMatch.id : null,\n    villa_name: villa.villa_name || villa.name || 'Unknown',\n    v_uuid: uuid,\n    custom_price: validPrices,\n    price_count: validPrices.length,\n    reason: wpMatch ? '' : 'v_uuid non trovato su WP'\n  }});\n}\n\nif (results.length === 0) {\n  return [{ json: { error: 'Nessuna villa Ibiza con prezzi validi', total_villas: villas.length, price_keys: Object.keys(priceData).length, wp_fetched: wpProperties.length, wp_matched: Object.keys(wpLookup).length, wp_debug: wpDebug } }];\n}\nreturn results;"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                0,
                0
            ],
            "id": "build-match-map",
            "name": "Build Match Map"
        },
        {
            "parameters": {
                "options": {}
            },
            "type": "n8n-nodes-base.splitInBatches",
            "typeVersion": 3,
            "position": [
                240,
                0
            ],
            "id": "loop-villas",
            "name": "Loop Villas"
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict",
                        "version": 3
                    },
                    "conditions": [
                        {
                            "id": "cond-not-skip",
                            "leftValue": "={{ $json.skip }}",
                            "rightValue": false,
                            "operator": {
                                "type": "boolean",
                                "operation": "equals"
                            }
                        }
                    ],
                    "combinator": "and"
                },
                "options": {}
            },
            "type": "n8n-nodes-base.if",
            "typeVersion": 2.3,
            "position": [
                480,
                0
            ],
            "id": "if-found",
