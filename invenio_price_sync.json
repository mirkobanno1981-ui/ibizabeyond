            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                720,
                120
            ],
            "id": "update-prices-wprentals",
            "name": "WP - Update Prices (WPRentals API)",
            "onError": "continueRegularOutput",
            "retryOnFail": true,
            "maxTries": 2,
            "waitBetweenTries": 3000,
            "disabled": true
        },
        {
            "parameters": {
                "jsCode": "// === LOG RESULT ===\n// Usa i dati originali dal loop (non dalla risposta WP)\nconst villaData = $('Loop Villas').item.json;\nconst resp = $input.first().json;\nlet status = 'UPDATED';\nif (villaData.skip) status = 'SKIPPED';\nelse if (resp.error || (resp.data && resp.data.status >= 400) || resp.code) status = 'ERROR';\nreturn [{ json: {\n  status: status,\n  villa: villaData.villa_name,\n  wp_id: villaData.wp_id || 'N/A',\n  v_uuid: villaData.v_uuid,\n  prices: villaData.price_count || 0,\n  reason: villaData.reason || (status === 'ERROR' ? JSON.stringify(resp).slice(0, 200) : '')\n}}];"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                960,
                0
            ],
            "id": "log-result",
            "name": "Log Result"
        },
        {
            "parameters": {
                "jsCode": "// === SUMMARY REPORT ===\nconst items = $input.all().map(i => i.json);\nconst updated = items.filter(i => i.status === 'UPDATED');\nconst skipped = items.filter(i => i.status === 'SKIPPED');\nconst errors = items.filter(i => i.status === 'ERROR');\nreturn [{ json: {\n  summary: `Price Sync: ${updated.length} updated, ${skipped.length} skipped, ${errors.length} errors`,\n  timestamp: new Date().toISOString(),\n  total: items.length,\n  updated: updated.length,\n  skipped: skipped.length,\n  errors: errors.length,\n  details: {\n    updated_villas: updated.map(v => `${v.villa} (WP#${v.wp_id}, ${v.prices} periodi)`),\n    skipped_villas: skipped.map(v => `${v.villa}: ${v.reason}`),\n    error_villas: errors.map(v => `${v.villa}: ${v.reason}`)\n  }\n}}];"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                480,
                -200
            ],
            "id": "summary-report",
            "name": "Summary Report"
        }
    ],
