            "typeVersion": 4.1,
            "position": [
                224,
                0
            ]
        },
        {
            "parameters": {
                "jsCode": "const villasNode = $('Invenio - Get Villas').first();\nif (!villasNode) throw new Error(\"Could not find Villas data.\");\n\nconst villas = villasNode.json.villas || [];\nlet itemsToProcess = [];\n\nvillas.forEach(v => {\n    if (v.destination !== 'Ibiza' || !v.v_uuid) return;\n    \n    const photos = v.photos || [];\n    const thumbnails = v.thumbnails || [];\n    let formattedPhotos = [];\n    \n    photos.forEach((url, i) => {\n        if (url) {\n            formattedPhotos.push({\n                v_uuid: v.v_uuid,\n                url: url,\n                thumbnail_url: thumbnails[i] || null,\n                sort_order: i\n            });\n        }\n    });\n    \n    if (formattedPhotos.length > 0) {\n        itemsToProcess.push({\n            v_uuid: v.v_uuid,\n            photos: formattedPhotos\n        });\n    }\n});\n\nreturn itemsToProcess.map(item => ({ json: item }));"
            },
            "id": "11abf81d-e6a6-4112-be22-4fece64f4ec8",
            "name": "Group Photos By Villa",
