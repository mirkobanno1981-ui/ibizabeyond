                "jsCode": "const loopItem = $('Loop Over Villas').item;\nlet photos = [];\nif (loopItem && loopItem.json && loopItem.json.photos) {\n    photos = loopItem.json.photos;\n}\nif (photos.length === 0) return [];\nreturn photos.map(p => ({ json: p }));"
            },
